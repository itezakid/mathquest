# ═══════════════════════════════════════════
# MathQuest — Environment Variables
# Salin file ini: cp .env.example .env.local
# JANGAN commit .env.local ke Git!
# ═══════════════════════════════════════════

# ── Supabase ──────────────────────────────
# Dari: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJYOUR_ANON_KEY_HERE

# Dari: Supabase → Project Settings → API → service_role key
# HANYA untuk server-side — jangan expose ke client!
SUPABASE_SERVICE_ROLE_KEY=eyJYOUR_SERVICE_ROLE_KEY_HERE

# ── Gemini AI ─────────────────────────────
# Dari: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_YOUR_GEMINI_API_KEY_HERE
